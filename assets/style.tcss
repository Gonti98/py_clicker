Screen{
  border: white 10%;
}

Button {
  border: round gray 50%;
  background: gray 0%;
}

Button:focus {
  border: round gray;
  background: gray 0%;
  text-style: underline;
}

/* MAIN MENU */
#logo{
  margin-top: 1;
  height: auto;
  margin-bottom: 6;
}

#menu{
  height: auto;
}

/* GAME */
#counter{
  dock: top;
  height: auto;
  width: 100%;
  border: double blue 50%;
  text-align: center;
}
